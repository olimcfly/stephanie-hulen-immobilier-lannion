# ===================================================
# Variables d'environnement — Stephanie Hulen Immobilier
# Copier ce fichier en .env et remplir les valeurs
# ===================================================

# Instance
INSTANCE_ID=stephanie-lannion
SITE_TITLE="Stephanie Hulen - Lannion"
SITE_DOMAIN=stephanie-hulen-immobilier-lannion.fr
ADMIN_EMAIL=admin@stephanie-hulen-immobilier-lannion.fr

# Base de données
DB_HOST=localhost
DB_NAME=ma_base_de_donnees
DB_USER=mon_utilisateur_db
DB_PASS=mon_mot_de_passe_db
DB_CHARSET=utf8mb4

# SMTP (envoi)
SMTP_HOST=mail.mon-domaine.fr
SMTP_PORT=465
SMTP_SECURE=ssl
SMTP_USER=admin@mon-domaine.fr
SMTP_PASS=mon_mot_de_passe_smtp
SMTP_FROM=contact@mon-domaine.fr
SMTP_FROM_NAME="Mon Agence Immobiliere"

# IMAP (réception)
IMAP_HOST=mail.mon-domaine.fr
IMAP_PORT=993
IMAP_SECURE=ssl
IMAP_USER=admin@mon-domaine.fr
IMAP_PASS=mon_mot_de_passe_imap

# Clés API (optionnel — les clés en DB priment)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=

# Debug
DEBUG_MODE=false
